{
  "apiVersion": 3,
  "name": "system-cars/video-modal",
  "version": "5.0.0",
  "title": "Video Modal",
  "category": "system-cars",
  "icon": "video-alt3",
  "description": "Video que se abre en modal popup. Soporta YouTube, Vimeo y archivos MP4.",
  "supports": {
    "html": false,
    "align": true
  },
  "textdomain": "system-cars-theme",

  "attributes": {
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "thumbnailUrl": {
      "type": "string",
      "default": ""
    },
    "thumbnailAlt": {
      "type": "string",
      "default": "Video Thumbnail"
    }
  },

  "editorScript": "file:../../dist/video-modal-block.js",
  "style": "file:../../dist/css/video-modal-style.css"
}
