{
  "apiVersion": 3,
  "name": "system-cars/video-modal",
  "title": "Video Modal",
  "category": "system-cars",
  "icon": "video-alt3",
  "description": "Video que se abre en modal popup.",
  "supports": { "html": false },
  "textdomain": "system-cars-theme",

  "attributes": {
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "thumbnailUrl": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "source": "html",
      "selector": ".video-title"
    },
    "description": {
      "type": "string",
      "source": "html",
      "selector": ".video-description"
    }
  },

  "editorScript": "file:../../dist/video-modal-block.js",
  "script": "file:../../dist/video-modal-frontend.js",
  "style": "file:../../dist/css/video-modal-style.css"
}
